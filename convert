#!/bin/bash

shopt -s nullglob

AUDIO_BITRATE="192k"
AUDIO_CODEC="aac" # Using standard 'aac' for compatibility. Change to 'aac_at' if on macOS specific builds.
LOG_LEVEL="error"

function get_audio_index() {
    local file="$1"
    local ainfo eng_idx first_idx

    ainfo=$(ffprobe -hide_banner -loglevel "$LOG_LEVEL" -select_streams a -show_entries stream=index:stream_tags=language -of csv=p=0 "$file" 2>/dev/null)

    if [ -z "$ainfo" ]; then echo ""; return; fi

    eng_idx=$(echo "$ainfo" | grep -iE ',eng$|,en$' | cut -d, -f1 | head -n1)

    if [ -n "$eng_idx" ]; then
        echo "$eng_idx"
    else
        first_idx=$(echo "$ainfo" | cut -d, -f1 | head -n1)
        echo "$first_idx"
    fi
}

function get_sub_index() {
    local file="$1"
    local sinfo eng_idx first_idx

    sinfo=$(ffprobe -hide_banner -loglevel "$LOG_LEVEL" -select_streams s -show_entries stream=index:stream_tags=language -of csv=p=0 "$file" 2>/dev/null)

    if [ -z "$sinfo" ]; then echo ""; return; fi

    eng_idx=$(echo "$sinfo" | grep -iE ',eng$|,en$' | cut -d, -f1 | head -n1)

    if [ -n "$eng_idx" ]; then
        echo "$eng_idx"
    else
        first_idx=$(echo "$sinfo" | cut -d, -f1 | head -n1)
        echo "$first_idx"
    fi
}

function ensure_vtt() {
    local input="$1"
    local base_name="$2"
    local vtt_file="${base_name}.vtt"

    if [ -f "$vtt_file" ]; then
        return
    fi

    if [ -f "${base_name}.srt" ]; then
        echo "   [SUB]: Converting external SRT to VTT..."
        ffmpeg -hide_banner -loglevel "$LOG_LEVEL" -y -i "${base_name}.srt" "$vtt_file" && return
    fi

    local sub_idx
    sub_idx=$(get_sub_index "$input")

    if [ -n "$sub_idx" ]; then
        echo "   [SUB]: Extracting internal track $sub_idx to VTT..."
        ffmpeg -hide_banner -loglevel "$LOG_LEVEL" -y -i "$input" -map "0:$sub_idx" "$vtt_file"
    fi
}

function process_file() {
    local file="$1"

    if [ ! -f "$file" ]; then return; fi

    local ext="${file##*.}"
    local base="${file%.*}"
    local mp4_out="${base}.mp4"

    if [ -f "$mp4_out" ] && [ "$file" != "$mp4_out" ]; then
        echo "[SKIP]: Target '$mp4_out' exists."
        ensure_vtt "$file" "$base"
        echo "   [DEL]: Removing source '$file'..."
        rm "$file"
        return
    fi

    if [ "$file" == "$mp4_out" ]; then
        ensure_vtt "$file" "$base"
        return
    fi

    echo "[CONV]: '$file' -> '$mp4_out'"

    local inputs=("-i" "$file")
    local map_opts=("-map" "0:v:0")
    local codec_opts=("-c:v" "copy" "-movflags" "+faststart")

    local audio_idx
    audio_idx=$(get_audio_index "$file")
    if [ -n "$audio_idx" ]; then
        map_opts+=("-map" "0:$audio_idx")
        codec_opts+=("-c:a" "$AUDIO_CODEC" "-b:a" "$AUDIO_BITRATE")
    else
        codec_opts+=("-an")
    fi

    local srt_ext="${base}.srt"
    local sub_idx=""

    if [ -f "$srt_ext" ]; then
        inputs+=("-i" "$srt_ext")
        map_opts+=("-map" "1:s:0")
        codec_opts+=("-c:s" "mov_text" "-metadata:s:s:0" "language=eng")
    else
        sub_idx=$(get_sub_index "$file")
        if [ -n "$sub_idx" ]; then
            map_opts+=("-map" "0:$sub_idx")
            codec_opts+=("-c:s" "mov_text" "-metadata:s:s:0" "language=eng")
        else
            codec_opts+=("-sn")
        fi
    fi

    ffmpeg -hide_banner -loglevel "$LOG_LEVEL" -stats \
        "${inputs[@]}" "${map_opts[@]}" "${codec_opts[@]}" "$mp4_out"

    if [ $? -eq 0 ]; then
        echo "   [OK]: Conversion successful."
        ensure_vtt "$file" "$base"
        rm "$file"
    else
        echo "   [ERR]: Conversion failed. Keeping source file."
        rm -f "$mp4_out"
    fi
}

if [ $# -eq 0 ]; then
    echo "--- Batch Mode (Current Folder) ---"
    for f in *.{mkv,avi,mov,wmv,mpg,mpeg,m4v,flv,webm}; do
        process_file "$f"
    done
    for f in *.mp4; do
        ensure_vtt "$f" "${f%.*}"
    done
else
    for f in "$@"; do
        process_file "$f"
    done
fi